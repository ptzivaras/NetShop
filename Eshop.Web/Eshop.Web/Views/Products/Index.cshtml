@model Eshop.Web.ViewModels.ProductsListViewModel
@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>All Products</h2>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Add Product
                </a>
            }
        </div>
    </div>

    <!-- Search & Filter -->
    <form asp-action="Index" method="get" class="mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search products..." />
            </div>
            <div class="col-md-2">
                <select name="categoryId" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <div class="input-group">
                    <span class="input-group-text">€</span>
                    <input type="number" name="minPrice" value="@Model.MinPrice" class="form-control" placeholder="Min" min="0" step="0.01" />
                </div>
            </div>
            <div class="col-md-2">
                <div class="input-group">
                    <span class="input-group-text">€</span>
                    <input type="number" name="maxPrice" value="@Model.MaxPrice" class="form-control" placeholder="Max" min="0" step="0.01" />
                </div>
            </div>
            <div class="col-md-1">
                <select name="inStock" class="form-select">
                    <option value="">All</option>
                    <option value="true" selected="@(Model.InStock == true)">In Stock</option>
                    <option value="false" selected="@(Model.InStock == false)">Out of Stock</option>
                </select>
            </div>
            <div class="col-md-1 d-flex gap-1">
                <button type="submit" class="btn btn-primary flex-grow-1">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary" title="Clear filters">✕</a>
            </div>
        </div>
    </form>

    <!-- Products Grid -->
    <div class="row">
        @foreach (var product in Model.Items)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(product.ImagePath))
                    {
                        <img src="@product.ImagePath" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;" />
                    }
                    else if (product.ImageBytes != null)
                    {
                        <img src="data:@product.ImageContentType;base64,@Convert.ToBase64String(product.ImageBytes)" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                            <span class="text-muted">No Image</span>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-truncate">@product.Description</p>
                        <p class="card-text">
                            <strong>€@product.Price.ToString("F2")</strong>
                        </p>
                        <p class="card-text">
                            <small class="text-muted">Stock: @product.StockQuantity</small>
                        </p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-1 flex-wrap">
                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        @if (product.StockQuantity > 0)
                        {
                            <button class="btn btn-sm btn-primary add-to-cart-btn"
                                    data-product-id="@product.Id"
                                    data-product-name="@product.Name">
                                Add to Cart
                            </button>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Add to Wishlist">♡</button>
                            </form>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-q="@Model.Query" asp-route-categoryId="@Model.CategoryId" asp-route-minPrice="@Model.MinPrice" asp-route-maxPrice="@Model.MaxPrice" asp-route-inStock="@Model.InStock">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
